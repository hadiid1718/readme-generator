# ============================================
# GitHub README Generator Pro - Server Config
# ============================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/readme-generator-pro

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Paddle
PADDLE_API_KEY=replace_with_paddle_api_key
PADDLE_WEBHOOK_SECRET=replace_with_paddle_webhook_secret
PADDLE_PRO_PRICE_ID=replace_with_paddle_pro_price_id
PADDLE_CHECKOUT_URL=https://pay.paddle.com/checkout/your_checkout_id
PADDLE_CUSTOMER_PORTAL_URL=https://customers.paddle.com
PADDLE_API_BASE_URL=https://api.paddle.com

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Email (for subscription expiration notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=README Generator Pro <noreply@readmepro.com>

# Default Admin (seeded on first run if no admin exists)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@readmepro.com
ADMIN_PASSWORD=Admin@123
